      "id": 14,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "<div style=\"padding: 20px; font-family: Arial; background: #1e1e1e; border-radius: 8px; color: #fff;\">\n  <h3 style=\"margin-top: 0;\">Edit Portfolio</h3>\n  \n  <div id=\"weightInputs\" style=\"margin: 20px 0;\">\n    <p style=\"color: #f39c12;\">Loading current weights...</p>\n  </div>\n  \n  <button id=\"updateBtn\" onclick=\"updateWeights()\" style=\"\n    padding: 12px 24px;\n    background: #27ae60;\n    color: white;\n    border: none;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 16px;\n    font-weight: bold;\n    margin-top: 10px;\n  \">\n    Update Portfolio\n  </button>\n  \n  <button onclick=\"resetWeights()\" style=\"\n    padding: 12px 24px;\n    background: #95a5a6;\n    color: white;\n    border: none;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 16px;\n    margin-left: 10px;\n  \">\n    Reset to Default\n  </button>\n  <div style=\"margin-top: 20px; padding-top: 15px; border-top: 1px solid #34495e;\">\n    <h4 style=\"margin: 0 0 10px 0; color: #bdc3c7;\">Add Stock</h4>\n    <div style=\"display: flex; gap: 10px; align-items: center;\">\n      <input \n        type=\"text\" \n        id=\"newTickerInput\"\n        placeholder=\"e.g. NVDA\" \n        maxlength=\"10\"\n        style=\"padding: 8px; background: #2c3e50; color: white; border: 1px solid #34495e; border-radius: 4px; width: 100px; text-transform: uppercase;\"\n      >\n      <button onclick=\"addStock()\" style=\"\n        padding: 8px 16px;\n        background: #2980b9;\n        color: white;\n        border: none;\n        border-radius: 4px;\n        cursor: pointer;\n        font-size: 14px;\n      \">+ Add</button>\n      <span id=\"addStockStatus\" style=\"font-size: 13px;\"></span>\n    </div>\n  </div>\n\n\n\n  <div id=\"totalWeight\" style=\"margin: 15px 0; font-size: 18px; font-weight: bold;\"></div>\n  <div id=\"result\" style=\"margin-top: 20px;\"></div>\n  \n  <script>\n    // initialize portfolio id (from grafana)\n    function getPortfolioID() {\n      const params = new URLSearchParams(window.location.search);\n      return params.get('var-portfolio') || 'template';\n    }\n\n    const portfolioID = getPortfolioID();\n\n    // Current weights (loaded from API)\n    let currentWeights = [];\n    let hasNewTickers = false;\n    \n    // Load current weights from API on init\n    async function loadCurrentWeights() {\n      try {\n        const response = await fetch(`http://localhost:8000/api/portfolio/${portfolioID}/weights`);\n        const data = await response.json();\n        \n        currentWeights = data.stocks;\n        initWeightInputs();\n      } catch (error) {\n        console.error('Failed to load weights:', error);\n        currentWeights = JSON.parse(JSON.stringify(defaultWeights));\n        initWeightInputs();\n      }\n    }\n\n    async function loadDefaultWeights() {\n      try {\n        const response = await fetch(`http://localhost:8000/api/portfolio/${portfolioID}/defaults`);\n        const data = await response.json();\n        return data.stocks;\n      } catch (error) {\n        console.error('Failed to load defaults:', error);\n        return null;\n      }\n    }\n\n\n    \n    // Initialize the weight inputs\n    function initWeightInputs() {\n      const container = document.getElementById('weightInputs');\n      container.innerHTML = '';\n      \n      currentWeights.forEach((stock, index) => {\n        const div = document.createElement('div');\n        div.style.cssText = 'margin: 10px 0; display: flex; align-items: center; gap: 10px;';\n        \n        div.innerHTML = `\n          <label style=\"width: 80px; font-weight: bold;\">${stock.symbol}:</label>\n          <input \n            type=\"range\" \n            id=\"weight_${index}\" \n            min=\"0\" max=\"100\" \n            value=\"${stock.weight * 100}\" \n            oninput=\"updateWeight(${index}, this.value)\"\n            style=\"flex: 1;\"\n          >\n          <input \n            type=\"number\" \n            id=\"weight_num_${index}\" \n            min=\"0\" max=\"100\" step=\"1\" \n            value=\"${(stock.weight * 100).toFixed(0)}\" \n            oninput=\"updateWeightFromNumber(${index}, this.value)\"\n            style=\"width: 60px; padding: 5px; background: #2c3e50; color: white; border: 1px solid #34495e; border-radius: 4px;\"\n          >\n          <span style=\"width: 30px;\">%</span>\n          <button \n            onclick=\"removeStock(${index})\"\n            style=\"padding: 4px 8px; background: #e74c3c; color: white; border: none; border-radius: 4px; cursor: pointer;\"\n            title=\"Remove stock (set weight to 0)\"\n          >✕</button>\n        `;\n        \n        container.appendChild(div);\n      });\n      \n      updateTotalDisplay();\n    }\n    \n    // Update weight from slider\n    function updateWeight(index, value) {\n      const weight = parseFloat(value) / 100;\n      currentWeights[index].weight = weight;\n      document.getElementById(`weight_num_${index}`).value = value;\n      updateTotalDisplay();\n    }\n    \n    // Update weight from number input\n    function updateWeightFromNumber(index, value) {\n      const weight = parseFloat(value) / 100;\n      currentWeights[index].weight = weight;\n      document.getElementById(`weight_${index}`).value = value;\n      updateTotalDisplay();\n    }\n\n    // zero out a stock (removing it)\n    function removeStock(index) {\n      currentWeights[index].weight = 0;\n      document.getElementById(`weight_${index}`).value = 0;\n      document.getElementById(`weight_num_${index}`).value = 0;\n      updateTotalDisplay();\n    }\n    \n    // Display total weight\n    function updateTotalDisplay() {\n      const total = currentWeights.reduce((sum, s) => sum + s.weight, 0);\n      const totalDiv = document.getElementById('totalWeight');\n      \n      const isValid = total >= 0.995 && total <= 1.005;\n      const color = isValid ? '#27ae60' : '#e74c3c';\n      \n      totalDiv.innerHTML = `\n        <span style=\"color: ${color};\">\n          Total Weight: ${(total * 100).toFixed(1)}%\n          ${isValid ? '✓' : 'Must sum to 100%'}\n        </span>\n      `;\n    }\n    \n    // Reset to default weights\n    async function resetWeights() {\n      const defaults = await loadDefaultWeights();\n      \n      if (!defaults || defaults.length === 0) {\n        document.getElementById('result').innerHTML = `\n          <div style=\"padding: 15px; background: #e74c3c; color: white; border-radius: 4px;\">\n            <strong>Reset Failed</strong><br>Could not load default weights.\n          </div>\n        `;\n        return;\n      }\n\n      currentWeights = JSON.parse(JSON.stringify(defaults));\n      initWeightInputs();\n      await updateWeights();\n    }\n\n\n    // add a new ticker to the portfolio\n    async function addStock() {\n      const input = document.getElementById('newTickerInput');\n      const status = document.getElementById('addStockStatus');\n      const symbol = input.value.trim().toUpperCase();\n      \n      if (!symbol) return;\n      \n      status.innerHTML = '<span style=\"color: #f39c12;\">Checking Ticker</span>';\n      \n      try {\n        const response = await fetch(`http://localhost:8000/api/portfolio/${portfolioID}/add-stock`, {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify({ symbol: symbol, weight: 0.10 })\n        });\n        \n        if (!response.ok) {\n          const error = await response.json();\n          throw new Error(error.detail || 'Failed to add stock');\n        }\n        \n        const data = await response.json();\n\n        if (data.is_new_ticker) {\n          hasNewTickers = true;\n        }\n        \n        // Update local weights and re-render\n        currentWeights = data.stocks;\n        initWeightInputs();\n        input.value = '';\n        status.innerHTML = `<span style=\"color: #27ae60;\">${symbol} added: adjust weights and click Update</span>`;\n        \n      } catch (error) {\n        status.innerHTML = `<span style=\"color: #e74c3c;\">✗ ${error.message}</span>`;\n      }\n\n\n    }\n    \n    // Send updated weights to API\n    async function updateWeights() {\n      const resultDiv = document.getElementById('result');\n      const btn = document.getElementById('updateBtn');\n      \n      // Validate total\n      const total = currentWeights.reduce((sum, s) => sum + s.weight, 0);\n      if (total < 0.995 || total > 1.005) {\n        resultDiv.innerHTML = `\n          <div style=\"padding: 15px; background: #e74c3c; color: white; border-radius: 4px;\">\n            <strong>Invalid Weights</strong><br>\n            Total must sum to ~100% (currently ${(total * 100).toFixed(1)}%)\n          </div>\n        `;\n        return;\n      }\n      \n      // Show loading\n      btn.disabled = true;\n      btn.style.background = '#95a5a6';\n      resultDiv.innerHTML = '<p style=\"color: #f39c12;\">Updating portfolio...</p>';\n      \n      try {\n        const response = await fetch('http://localhost:8000/api/portfolio/update-weights', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n          },\n          body: JSON.stringify({\n            port_id: portfolioID,\n            stocks: currentWeights\n          })\n        });\n        \n        if (!response.ok) {\n          const error = await response.json();\n          throw new Error(error.detail || 'Update failed');\n        }\n        \n        const data = await response.json();\n        \n        resultDiv.innerHTML = `\n          <div style=\"padding: 15px; background: #27ae60; color: white; border-radius: 4px;\">\n            <strong>Portfolio Updated</strong><br><br>\n            <strong>Latest Metrics:</strong><br>\n            Beta: ${data.metrics.beta.toFixed(3)}<br>\n            Alpha: ${data.metrics.alpha.toFixed(3)}<br>\n            Sharpe: ${data.metrics.sharpe.toFixed(3)}<br>\n            Value: $${data.metrics.value.toFixed(2)}<br>\n            Return: ${data.metrics.return_pct.toFixed(2)}%<br><br>\n            <em>Refreshing dashboard...</em>\n          </div>\n        `;\n        \n        // Auto-refresh dashboard after 2 seconds (7 for ticker additions)\n        const reloadDelay = hasNewTickers ? 7000 : 2000;\n\n        resultDiv.innerHTML = `\n          <div style=\"padding: 15px; background: #27ae60; color: white; border-radius: 4px;\">\n            <strong>Portfolio Updated</strong><br><br>\n            ...metrics...\n            <em>${hasNewTickers ? 'Fetching new ticker data, refreshing in 7s...' : 'Refreshing dashboard...'}</em>\n          </div>\n        `;\n\n        setTimeout(() => { window.top.location.reload(); }, reloadDelay);\n\n        // reset flag after update\n        hasNewTickers = false;\n        \n      } catch (error) {\n        resultDiv.innerHTML = `\n          <div style=\"padding: 15px; background: #e74c3c; color: white; border-radius: 4px;\">\n            <strong>Update Failed</strong><br>\n            ${error.message}\n          </div>\n        `;\n      } finally {\n        btn.disabled = false;\n        btn.style.background = '#27ae60';\n      }\n    }\n    \n    // Initialize on load\n    loadCurrentWeights();\n  </script>\n</div>",
        "mode": "html"
      },
      "pluginVersion": "12.1.1",
      "title": "Weight Adjustments",
      "type": "text"
    },
